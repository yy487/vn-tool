[
  {
    "message": "あ・・・",
    "_idx": 0,
    "_offset": "0x0068"
  },
  {
    "message": "約束通り、脱いでるだろうな？",
    "_idx": 1,
    "_offset": "0x007c"
  },
  {
    "message": "う、うん・・・",
    "_idx": 2,
    "_offset": "0x00c8"
  },
  {
    "message": "ゆかり？",
    "_idx": 3,
    "_offset": "0x00ff"
  },
  {
    "message": "[1081]くん。生まれたよ",
    "_idx": 4,
    "_offset": "0x0181"
  },
  {
    "message": "何が？",
    "_idx": 5,
    "_offset": "0x019f"
  },
  {
    "message": "何がじゃないよ。桃里さんの赤ちゃん",
    "_idx": 6,
    "_offset": "0x01bd"
  },
  {
    "message": "桃里さんの様子は？",
    "_idx": 7,
    "_offset": "0x01eb"
  },
  {
    "message": "うん。ちょっと時間がかかったから疲れて寝てるけど、健康状態に問題はないよ",
    "_idx": 8,
    "_offset": "0x0215"
  },
  {
    "message": "そうか・・・良かった",
    "_idx": 9,
    "_offset": "0x0269"
  },
  {
    "message": "でもね、出産のとき・・・破水と一緒に中に残ってた[1081]くんの精液が流れ出て、すっごく気まずかったんだよ",
    "_idx": 10,
    "_offset": "0x02ad"
  },
  {
    "message": "ゆかりの出産のときもしてあげるよ",
    "_idx": 11,
    "_offset": "0x031b"
  },
  {
    "message": "しなくていいよ！・・・もう。本当に[1081]くんは鬼畜なんだから",
    "_idx": 12,
    "_offset": "0x036b"
  },
  {
    "message": "[028f]・・・もう！[0280]",
    "_idx": 13,
    "_offset": "0x0431"
  },
  {
    "message": "どうしたんだ？随分怒ってるけど・・・",
    "_idx": 14,
    "_offset": "0x044d"
  },
  {
    "message": "桃里さんの旦那さんが、いきなり更衣室に入ってきたんだよ",
    "_idx": 15,
    "_offset": "0x0489"
  },
  {
    "message": "[0294]へ？[0280]",
    "_idx": 16,
    "_offset": "0x04cb"
  },
  {
    "message": "しかも、“赤ちゃんはドコですか？”だって！慌てもしないで、じーっとみんなの着替えを見てるんだよ！",
    "_idx": 17,
    "_offset": "0x04eb"
  },
  {
    "message": "はー。羨ましい",
    "_idx": 18,
    "_offset": "0x0557"
  },
  {
    "message": "羨ましくないよ！桃里さんの旦那さんなんだから、桃里さんの裸を見ればいいんだよ！",
    "_idx": 19,
    "_offset": "0x057d"
  },
  {
    "message": "そ、そうだな",
    "_idx": 20,
    "_offset": "0x05d7"
  },
  {
    "message": "ゆかり、約束を守ってるか調べに来たぞ",
    "_idx": 21,
    "_offset": "0x064d"
  },
  {
    "message": "わかったよ・・・こっちに、来て",
    "_idx": 22,
    "_offset": "0x0689"
  },
  {
    "message": "どこに行くんだ？",
    "_idx": 23,
    "_offset": "0x06b3"
  },
  {
    "message": "・・・分娩室。新しい分娩室が出来て、使ってないから人が来ないよ",
    "_idx": 24,
    "_offset": "0x06db"
  },
  {
    "message": "・・・ぱんつ履いてる",
    "_idx": 25,
    "_offset": "0x0749"
  },
  {
    "message": "うん・・・",
    "_idx": 26,
    "_offset": "0x0775"
  },
  {
    "message": "パンツは履いちゃダメって言ったよな",
    "_idx": 27,
    "_offset": "0x07d4"
  },
  {
    "message": "そっ、そんなの出来ないもんっ",
    "_idx": 28,
    "_offset": "0x080e"
  },
  {
    "message": "じゃあ、おしおきだっ",
    "_idx": 29,
    "_offset": "0x0836"
  },
  {
    "message": "おしおきって・・・きゃあっ！",
    "_idx": 30,
    "_offset": "0x0862"
  },
  {
    "message": "[028f]れーっつ、おしおきターイム[0280]",
    "_idx": 31,
    "_offset": "0x08b3"
  },
  {
    "message": "[028f]いやぁっ、やぁっ。えっ、何？ええっ？[0280]",
    "_idx": 32,
    "_offset": "0x08e9"
  },
  {
    "message": "パンツ履いてる悪い子にはおしおきしちゃいマース",
    "_idx": 33,
    "_offset": "0x091d"
  },
  {
    "message": "ちょっと[1081]くんっ。やだっ・・・ほどけないよぉっ",
    "_idx": 34,
    "_offset": "0x0963"
  },
  {
    "message": "そして、おしおきその１。安全カミソリ～♪",
    "_idx": 35,
    "_offset": "0x09ac"
  },
  {
    "message": "そんなものでどうするの？",
    "_idx": 36,
    "_offset": "0x09ec"
  },
  {
    "message": "[0294]剃毛[0280]",
    "_idx": 37,
    "_offset": "0x0a10"
  },
  {
    "message": "だめだよ！剃っちゃ！",
    "_idx": 38,
    "_offset": "0x0a30"
  },
  {
    "message": "更に、おしおきその２ぃ",
    "_idx": 39,
    "_offset": "0x0a50"
  },
  {
    "message": "あーん、もうっ。私の話聞いてよっ",
    "_idx": 40,
    "_offset": "0x0a7e"
  },
  {
    "message": "[0294][038a]ク・ス・コ[0380][0280]",
    "_idx": 41,
    "_offset": "0x0ab9"
  },
  {
    "message": "[028f]きゃぁぁぁっ。[0280]それ使うなんて言わないよね？",
    "_idx": 42,
    "_offset": "0x0ae3"
  },
  {
    "message": "[028f]おふこーす！[0280]勿論使ってゆかりの中をしっかりのぞきマース",
    "_idx": 43,
    "_offset": "0x0b1d"
  },
  {
    "message": "あーーんっやだやだやだぁっ",
    "_idx": 44,
    "_offset": "0x0b6f"
  },
  {
    "message": "今すぐパンツを脱ぐと約束すれば、やめてあげよう",
    "_idx": 45,
    "_offset": "0x0b95"
  },
  {
    "message": "そっ、そんなの約束できないよ！",
    "_idx": 46,
    "_offset": "0x0bdb"
  },
  {
    "message": "じゃあ、おしおきしちゃおっかナー",
    "_idx": 47,
    "_offset": "0x0c05"
  },
  {
    "message": "[028f]きゃあああっ。[0280]しますします。約束するよっ",
    "_idx": 48,
    "_offset": "0x0c3d"
  },
  {
    "message": "はぁはぁ・・・",
    "_idx": 49,
    "_offset": "0x0cb5"
  },
  {
    "message": "どうして、パンツ履いてるんだよ",
    "_idx": 50,
    "_offset": "0x0cf1"
  },
  {
    "message": "だって、絶対見えるよ・・・そんなの出来ないよ",
    "_idx": 51,
    "_offset": "0x0d27"
  },
  {
    "message": "でもやれ",
    "_idx": 52,
    "_offset": "0x0d5f"
  },
  {
    "message": "出来ないもん",
    "_idx": 53,
    "_offset": "0x0d7f"
  },
  {
    "message": "やれったらやれ",
    "_idx": 54,
    "_offset": "0x0d97"
  },
  {
    "message": "出来ないったら出来ない",
    "_idx": 55,
    "_offset": "0x0dbd"
  },
  {
    "message": "・・・",
    "_idx": 56,
    "_offset": "0x0ddf"
  },
  {
    "message": "それに・・・",
    "_idx": 57,
    "_offset": "0x0dfd"
  },
  {
    "message": "ん？",
    "_idx": 58,
    "_offset": "0x0e15"
  },
  {
    "message": "どうして・・・私なんて構うの・・・・・・[1081]くんには、私なんかよりずっと綺麗な女の人がいっぱいいるのに・・・・・・",
    "_idx": 59,
    "_offset": "0x0e42"
  },
  {
    "message": "ゆかり・・・",
    "_idx": 60,
    "_offset": "0x0ebe"
  },
  {
    "message": "[1081]くんは、私がずっと[1081]くんのこと好きだってこと知ってるくせに・・・・・・昔みたく構われてると・・・私・・・・・・わかんなくなっちゃうよ",
    "_idx": 61,
    "_offset": "0x0ee2"
  },
  {
    "message": "・・・",
    "_idx": 62,
    "_offset": "0x0f75"
  },
  {
    "message": "おっぱい揉まれたり・・・屋上でおしっこさせられたり・・・・・・こんなに構われてると・・・また好きな気持ちが抑えられなくなっちゃうよ・・・・・・私のことが好きでも何でもないなら、こんなことしないでよ",
    "_idx": 63,
    "_offset": "0x0f93"
  },
  {
    "message": "ゆかり、俺は・・・",
    "_idx": 64,
    "_offset": "0x1064"
  },
  {
    "message": "ゆかりのことが好きだ",
    "_idx": 65,
    "_offset": "0x110d"
  },
  {
    "message": "[1081]くん・・・！？",
    "_idx": 66,
    "_offset": "0x1139"
  },
  {
    "message": "俺たちは色々あって・・・離れ離れだったけど、再会は偶然なんかじゃなく・・・こんなことがなくても再会したんだと思う",
    "_idx": 67,
    "_offset": "0x1155"
  },
  {
    "message": "・・・[1081]くん",
    "_idx": 68,
    "_offset": "0x11dd"
  },
  {
    "message": "会いたいって思っていたから・・・会えたんだ",
    "_idx": 69,
    "_offset": "0x11f5"
  },
  {
    "message": "うん・・・",
    "_idx": 70,
    "_offset": "0x1237"
  },
  {
    "message": "俺は・・・もうゆかりと離れたくないよ",
    "_idx": 71,
    "_offset": "0x124d"
  },
  {
    "message": "私も・・・",
    "_idx": 72,
    "_offset": "0x1289"
  },
  {
    "message": "俺は・・・ゆかりのことも好きだ",
    "_idx": 73,
    "_offset": "0x12bc"
  },
  {
    "message": "・・・[1081]くん",
    "_idx": 74,
    "_offset": "0x12f2"
  },
  {
    "message": "でも、別れたとはいえ、るり香のおなかにいる子は俺の子なんだと思う。だから・・・それを放り出すわけにもいかない",
    "_idx": 75,
    "_offset": "0x130a"
  },
  {
    "message": "うん・・・",
    "_idx": 76,
    "_offset": "0x138e"
  },
  {
    "message": "ゆかりのこと・・・好きだよ",
    "_idx": 77,
    "_offset": "0x13a4"
  },
  {
    "message": "私もだよ・・・[1081]くん",
    "_idx": 78,
    "_offset": "0x13d6"
  },
  {
    "message": "俺は・・・るり香のことが大事だ",
    "_idx": 79,
    "_offset": "0x140a"
  },
  {
    "message": "[1081]・・・くん",
    "_idx": 80,
    "_offset": "0x1440"
  },
  {
    "message": "だから、ゆかりがそういうなら、止めるよ",
    "_idx": 81,
    "_offset": "0x1458"
  },
  {
    "message": "待ってよ！私のこと、全然好きじゃないのに、えっちなことしてたの？",
    "_idx": 82,
    "_offset": "0x1496"
  },
  {
    "message": "そういうわけじゃないけど・・・",
    "_idx": 83,
    "_offset": "0x14e2"
  },
  {
    "message": "私のこと・・・嫌い？",
    "_idx": 84,
    "_offset": "0x1518"
  },
  {
    "message": "そうじゃないよ。だから、るり香が・・・",
    "_idx": 85,
    "_offset": "0x1538"
  },
  {
    "message": "・・・・・・・",
    "_idx": 86,
    "_offset": "0x1576"
  },
  {
    "message": "わかってくれよ",
    "_idx": 87,
    "_offset": "0x1590"
  },
  {
    "message": "それじゃ・・・・・・最後まで・・・してよ",
    "_idx": 88,
    "_offset": "0x15b6"
  },
  {
    "message": "・・・ゆかり？",
    "_idx": 89,
    "_offset": "0x15ea"
  },
  {
    "message": "もう最後にするから・・・・・・私も思い出に・・・するから",
    "_idx": 90,
    "_offset": "0x1610"
  },
  {
    "message": "ああっ・・・んあっ",
    "_idx": 91,
    "_offset": "0x168f"
  },
  {
    "message": "ゆかりは、狭くぎこちなくて。",
    "_idx": 92,
    "_offset": "0x16a9"
  },
  {
    "message": "はぁっ・・・あんっ・・・いっ・・・",
    "_idx": 93,
    "_offset": "0x16dd"
  },
  {
    "message": "たった一人の男を待ちつづけていたそこからは、一条の血が流れていた。",
    "_idx": 94,
    "_offset": "0x1707"
  },
  {
    "message": "ひぃっ・・・あふっ・・・はぁっ・・・はぁっ",
    "_idx": 95,
    "_offset": "0x1761"
  },
  {
    "message": "なのに、俺にはるり香の顔ばかりがちらついて。",
    "_idx": 96,
    "_offset": "0x1793"
  },
  {
    "message": "あぁ・・・あんっ・・・[1081]くんっ・・・",
    "_idx": 97,
    "_offset": "0x17d7"
  },
  {
    "message": "一生懸命なゆかりを見て、哀しい気持ちで一杯だった。",
    "_idx": 98,
    "_offset": "0x1803"
  },
  {
    "message": "ああっ・・・[1081]くんっ・・・いくっ・・・・・・いっちゃ・・・うぅっ",
    "_idx": 99,
    "_offset": "0x184d"
  },
  {
    "message": "・・・ごめんね",
    "_idx": 100,
    "_offset": "0x1906"
  },
  {
    "message": "ゆかり・・・",
    "_idx": 101,
    "_offset": "0x1920"
  },
  {
    "message": "私・・・わがままいって・・・[1081]くんを困らせちゃったよね",
    "_idx": 102,
    "_offset": "0x1944"
  },
  {
    "message": "・・・",
    "_idx": 103,
    "_offset": "0x1986"
  },
  {
    "message": "ごめんね。もうこれで本当に忘れるから。これからはるり香さんと[1081]くんの応援再開！・・・だよ",
    "_idx": 104,
    "_offset": "0x19a4"
  },
  {
    "message": "ゆかりさーん。リネン室に届いた新しい・・・",
    "_idx": 105,
    "_offset": "0x1a08"
  },
  {
    "message": "はーい。今行きまーす！じゃあね・・・[1081]くん",
    "_idx": 106,
    "_offset": "0x1a5e"
  },
  {
    "message": "大きくなったゆかりは、当然のように小さな昔のゆかりとは違っていて。",
    "_idx": 107,
    "_offset": "0x1ae1"
  },
  {
    "message": "でも、想いが熱いほとばしりになって太股を伝う雫になるほどの時は流れているから。",
    "_idx": 108,
    "_offset": "0x1b2b"
  },
  {
    "message": "俺のことを想っていてくれているところだけは、そのまま。",
    "_idx": 109,
    "_offset": "0x1b81"
  },
  {
    "message": "んっ・・・あっ・・・はぁっ",
    "_idx": 110,
    "_offset": "0x1bcf"
  },
  {
    "message": "連日の愛撫のせいか、想いのせいか。指がかき回すほどに、ゆかりの中で粘膜が熱くからみつく。",
    "_idx": 111,
    "_offset": "0x1bf1"
  },
  {
    "message": "ゆかり・・・",
    "_idx": 112,
    "_offset": "0x1c55"
  },
  {
    "message": "あんっ・・・[1081]くん・・・好き・・・",
    "_idx": 113,
    "_offset": "0x1c79"
  },
  {
    "message": "俺は、意を決して。",
    "_idx": 114,
    "_offset": "0x1ca3"
  },
  {
    "message": "ゆかりっ",
    "_idx": 115,
    "_offset": "0x1cc1"
  },
  {
    "message": "抱きかかえたまま、後ろから一気に突き刺していく。",
    "_idx": 116,
    "_offset": "0x1cd1"
  },
  {
    "message": "ひっ・・・んあっ・・・あぁ・・・",
    "_idx": 117,
    "_offset": "0x1d19"
  },
  {
    "message": "僅かな抵抗がプツリと切れると・・・後は奥まで。",
    "_idx": 118,
    "_offset": "0x1d41"
  },
  {
    "message": "棍棒みたいに逞しくカタくなったこわばりは、あっけないほどにずぶずぶと飲み込まれていく。",
    "_idx": 119,
    "_offset": "0x1d77"
  },
  {
    "message": "はぁ・・・はぁ・・・",
    "_idx": 120,
    "_offset": "0x1dd9"
  },
  {
    "message": "まさぐった結合部にイヤらしくからみついた粘液はゆかりの匂いと・・・鉄の味。",
    "_idx": 121,
    "_offset": "0x1df5"
  },
  {
    "message": "手がかりもないままに、俺だけを待ち続けた処女の・・・ゆかりの血の味。",
    "_idx": 122,
    "_offset": "0x1e47"
  },
  {
    "message": "あっ・・・んぅ・・・あぅ・・・",
    "_idx": 123,
    "_offset": "0x1ea3"
  },
  {
    "message": "なのに。処女なのに、こんなにもイヤらしく、乱れて・・・",
    "_idx": 124,
    "_offset": "0x1ec9"
  },
  {
    "message": "ゆかり・・・で・・・出るよ",
    "_idx": 125,
    "_offset": "0x1f0b"
  },
  {
    "message": "あっ・・・いいよ・・・出してぇ・・・はあぁっ",
    "_idx": 126,
    "_offset": "0x1f3d"
  },
  {
    "message": "くっ",
    "_idx": 127,
    "_offset": "0x1f75"
  },
  {
    "message": "あっ・・・ああああーーー・・・んっ",
    "_idx": 128,
    "_offset": "0x1f91"
  },
  {
    "message": "はぁ・・・はぁ・・・はぁ・・・はぁ・・・",
    "_idx": 129,
    "_offset": "0x2004"
  },
  {
    "message": "ゆかり・・・",
    "_idx": 130,
    "_offset": "0x2038"
  },
  {
    "message": "[1081]くん・・・・・・好きだよ",
    "_idx": 131,
    "_offset": "0x205c"
  },
  {
    "message": "ん・・・",
    "_idx": 132,
    "_offset": "0x20b6"
  },
  {
    "message": "な、なんだよ",
    "_idx": 133,
    "_offset": "0x20ca"
  },
  {
    "message": "なんだか、照れくさいよ",
    "_idx": 134,
    "_offset": "0x20ee"
  },
  {
    "message": "ばか",
    "_idx": 135,
    "_offset": "0x2110"
  },
  {
    "message": "私・・・これからも[1081]くんのこと、好きでいいんだよね",
    "_idx": 136,
    "_offset": "0x212c"
  },
  {
    "message": "パンツをはかなければな",
    "_idx": 137,
    "_offset": "0x216a"
  },
  {
    "message": "ええ～～っ！まだその約束って生きてるの？",
    "_idx": 138,
    "_offset": "0x21be"
  },
  {
    "message": "もちろん",
    "_idx": 139,
    "_offset": "0x21f2"
  },
  {
    "message": "ずるいよ。普通、こういう・・・関係になったら・・・・・・そういう約束はナシしじゃないの？",
    "_idx": 140,
    "_offset": "0x2212"
  },
  {
    "message": "[0294]アリ[0280]",
    "_idx": 141,
    "_offset": "0x2276"
  },
  {
    "message": "そんなぁ",
    "_idx": 142,
    "_offset": "0x2296"
  },
  {
    "message": "ゆかりは以後ノーパンにすること",
    "_idx": 143,
    "_offset": "0x22aa"
  },
  {
    "message": "しないよー！",
    "_idx": 144,
    "_offset": "0x2306"
  },
  {
    "message": "ノーパンだったら・・・・・・ゆかりと付き合いたいな",
    "_idx": 145,
    "_offset": "0x231e"
  },
  {
    "message": "ええっ・・・・・・・・・で、でもダメだよ！",
    "_idx": 146,
    "_offset": "0x2380"
  },
  {
    "message": "ふーん",
    "_idx": 147,
    "_offset": "0x23b6"
  },
  {
    "message": "もうっ。[1081]くん！",
